<odoo>
    <record id="library_borrow_wizard_view_form" model="ir.ui.view">
        <field name="name">library.borrow.wizard.form</field>
        <field name="model">library.borrow.wizard</field>
        <field name="arch" type="xml">
            <form string="Borrow Book">
                <group>
                    <field name="book_id"/>
                    <field name="member_id"/>
                    <field name="borrow_date"/>
                    <field name="expected_return_date"/>
                    <field name="note"/>
                </group>

                <footer>
                    <button name="action_confirm"
                            string="Xac nhan muon"
                            type="object"
                            class="oe_highlight"/>
                    <button string="Huy"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="library_borrow_wizard_action" model="ir.actions.act_window">
        <field name="name">Borrow Book</field>
        <field name="res_model">library.borrow.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="library_borrow_wizard_view_form"/>
        <field name="target">new</field>
    </record>
</odoo>