<odoo>
    <record id="library_book_view_list" model="ir.ui.view">
        <field name="name">library.book.list</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <list string="Books">
                <field name="name"/>
                <field name="isbn"/>
                <field name="author"/>
                <field name="category_id"/>
                <field name="total_copies"/>
                <field name="borrowed_copies"/>
                <field name="available_copies"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="library_book_view_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form string="Book">    
                <header>
                    <button name="action_open_borrow_wizard"
                            string="Muon sach"
                            type="object"
                            class="oe_highlight"
                            groups="library.group_library_user,library.group_library_manager"
                            invisible="state != 'available'"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="isbn"/>
                            <field name="author"/>
                            <field name="category_id"/>
                            <field name="publisher_date"/>
                        </group>
                        <group>
                            <field name="total_copies"/>
                            <field name="borrowed_copies" readonly="1"/>
                            <field name="available_copies" readonly="1"/>
                            <field name="state" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="library_book_view_search" model="ir.ui.view">
        <field name="name">library.book.search</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <search string="Books">
                <field name="name"/>
                <field name="isbn"/>
                <field name="author"/>
                <field name="category_id"/>
            </search>
        </field>
    </record>
</odoo>
