<odoo>
    <record id="library_member_view_list" model="ir.ui.view">
        <field name="name">library.member.list</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <list string="Members">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="join_date"/>
                <field name="active_loan_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="library_member_view_form" model="ir.ui.view">
        <field name="name">library.member.form</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <form string="Member">
                <header>
                    <button name="action_open_borrow_wizard"
                            string="Muon sach"
                            type="object"
                            class="oe_highlight"
                            groups="library.group_library_user,library.group_library_manager"
                            invisible="not active"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="join_date"/>
                            <field name="active_loan_count" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="library_member_view_search" model="ir.ui.view">
        <field name="name">library.member.search</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <search string="Members">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
            </search>
        </field>
    </record>
</odoo>
