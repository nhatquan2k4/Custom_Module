<odoo>
    <record id="library_book_action" model="ir.actions.act_window">
        <field name="name">Books</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="library_book_view_search"/>
    </record>

    <record id="library_category_action" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">library.category</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="library_category_view_search"/>
    </record>

    <record id="library_member_action" model="ir.actions.act_window">
        <field name="name">Members</field>
        <field name="res_model">library.member</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="library_member_view_search"/>
    </record>

    <record id="library_loan_action" model="ir.actions.act_window">
        <field name="name">Loans</field>
        <field name="res_model">library.loan</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="library_loan_view_search"/>
    </record>

    <menuitem id="library_menu_root"
          name="Library"
          sequence="10"
          groups="library.group_library_reader,library.group_library_user,library.group_library_manager"/>

    <menuitem id="library_book_menu"
          name="Books"
          parent="library_menu_root"
          action="library_book_action"
          sequence="10"
          groups="library.group_library_reader,library.group_library_user,library.group_library_manager"/>

    <menuitem id="library_category_menu"
          name="Categories"
          parent="library_menu_root"
          action="library_category_action"
          sequence="20"
          groups="library.group_library_reader,library.group_library_user,library.group_library_manager"/>

    <menuitem id="library_member_menu"
          name="Members"
          parent="library_menu_root"
          action="library_member_action"
          sequence="30"
          groups="library.group_library_user,library.group_library_manager"/>

    <menuitem id="library_loan_menu"
          name="Loans"
          parent="library_menu_root"
          action="library_loan_action"
          sequence="40"
          groups="library.group_library_user,library.group_library_manager"/>
</odoo>
