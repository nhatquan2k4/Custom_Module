<odoo>
    <record id="view_sales_commission_approval_wizard_form" model="ir.ui.view">
        <field name="name">sales.commission.approval.wizard.form</field>
        <field name="model">sales.commission.approval.wizard</field>
        <field name="arch" type="xml">
            <form string="Duyet phieu thuong">
                <group>
                    <field name="action" widget="radio"/>
                    <field name="note"/>
                </group>
                <footer>
                    <button name="action_confirm"
                            string="Xac nhan"
                            type="object"
                            class="btn-primary"/>
                    <button string="Huy"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
