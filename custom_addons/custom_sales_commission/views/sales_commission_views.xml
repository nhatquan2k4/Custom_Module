<odoo>
    <record id="view_sales_commission_list" model="ir.ui.view">
        <field name="name">sales.commission.list</field>
        <field name="model">sales.commission</field>
        <field name="arch" type="xml">
            <list string="Phieu thuong">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="period_from"/>
                <field name="period_to"/>
                <field name="sale_amount_total"/>
                <field name="commission_amount_total"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_sales_commission_form" model="ir.ui.view">
        <field name="name">sales.commission.form</field>
        <field name="model">sales.commission</field>
        <field name="arch" type="xml">
            <form string="Phieu thuong">
                <header>
                    <button name="action_generate_lines"
                            string="Tinh thuong"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'approved'"/>
                    <button name="action_submit"
                            string="Gui duyet"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_open_approval_wizard"
                            string="Duyet / Tu choi"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'to_approve'"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,to_approve,approved,rejected"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="employee_id"/>
                            <field name="salesperson_user_id"/>
                            <field name="company_id"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="period_from"/>
                            <field name="period_to"/>
                            <field name="sale_amount_total"/>
                            <field name="commission_amount_total"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Chi tiet thuong">
                            <field name="line_ids" readonly="state == 'approved'">
                                <list editable="bottom">
                                    <field name="sale_order_id"/>
                                    <field name="order_date"/>
                                    <field name="delivery_date"/>
                                    <field name="sale_amount"/>
                                    <field name="commission_rate"/>
                                    <field name="commission_amount"/>
                                    <field name="delivery_status_snapshot"/>
                                </list>
                            </field>
                        </page>
                        <page string="Thong tin duyet">
                            <group>
                                <group>
                                    <field name="approved_by"/>
                                    <field name="approved_date"/>
                                    <field name="approval_note"/>
                                </group>
                                <group>
                                    <field name="rejected_by"/>
                                    <field name="rejected_date"/>
                                    <field name="rejection_reason"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sales_commission" model="ir.actions.act_window">
        <field name="name">Phieu thuong</field>
        <field name="res_model">sales.commission</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="server_action_sales_commission_approval_wizard" model="ir.actions.server">
        <field name="name">Duyet / Tu choi phieu thuong</field>
        <field name="model_id" ref="model_sales_commission"/>
        <field name="binding_model_id" ref="model_sales_commission"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_open_approval_wizard()</field>
    </record>

    <menuitem id="menu_sales_commission_root"
              name="Thuong kinh doanh"
              sequence="50"/>

    <menuitem id="menu_sales_commission"
              name="Phieu thuong"
              parent="menu_sales_commission_root"
              action="action_sales_commission"
              sequence="10"/>
    <menuitem id="menu_sales_commission_report"
              name="Bao cao thuong"
              parent="custom_sales_commission.menu_sales_commission_root"
              action="action_sales_commission_report_wizard"
              sequence="20"/>
</odoo>
