<odoo>
    <record id="view_test1_list" model="ir.ui.view">
        <field name="name">test.1.list</field>
        <field name="model">test.1</field>
        <field name="arch" type="xml">
            <list string="Test 1">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_test1_form" model="ir.ui.view">
        <field name="name">test.1.form</field>
        <field name="model">test.1</field>
        <field name="arch" type="xml">
            <form string="Test Command Tuples">
                <header>
                    <button name="action_test_command_create"
                            string="Test Create Commands"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_test_command_update"
                            string="Test Update Commands"
                            type="object"/>
                    <button name="action_test_command_link_and_unlink"
                            string="Test Link/Unlink Commands"
                            type="object"/>
                    <button name="action_test_command_clear"
                            string="Test Clear Commands"
                            type="object"/>
                    <button name="action_test_command_set"
                            string="Test Set Commands"
                            type="object"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_test1" model="ir.actions.act_window">
        <field name="name">Test Command Tuples</field>
        <field name="res_model">test.1</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_test1"
              name="Test Command Tuples"
              parent="menu_sales_commission_root"
              action="action_test1"
              sequence="90"/>
</odoo>
