<odoo>
    <record id="view_urgent_delivery_approval_wizard_form" model="ir.ui.view">
        <field name="name">urgent.delivery.approval.wizard.form</field>
        <field name="model">urgent.delivery.approval.wizard</field>
        <field name="arch" type="xml">
            <form string="Duyet giao gap">
                <group>
                    <field name="sale_order_id"/>
                    <field name="note"/>
                </group>
                <footer>
                    <button name="action_approve"
                            string="Duyet"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_reject"
                            string="Tu choi"
                            type="object"
                            class="btn-secondary"/>
                    <button string="Huy"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>